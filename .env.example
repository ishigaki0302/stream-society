# LLM Backend (optional, mock used by default)
LLM_BACKEND=mock
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# MMDAgent-EX Bridge (optional, mock used by default)
MMDAGENT_BRIDGE=mock
MMDAGENT_WS_URL=ws://localhost:9000/bridge

# Simulation defaults
DEFAULT_SEED=42
DEFAULT_POLICY=random

# Storage
DATA_DIR=data
OUTPUT_DIR=outputs
DB_PATH=db/sim.sqlite
